    task.wait(0.3)
    for _, c in ipairs(VI_GetContainers()) do VI_PatchTree(c) end

    -- Bắt đầu watcher realtime
    VI_StartWatchers()

    -- Patch thêm 2 lần nữa để chắc chắn bắt được các element render muộn
    task.wait(0.7)
    for _, c in ipairs(VI_GetContainers()) do VI_PatchTree(c) end
    task.wait(1.5)
    for _, c in ipairs(VI_GetContainers()) do VI_PatchTree(c) end

    -- Sau 2s bắt đầu theo dõi bền vững từng element đã patch
    for _, c in ipairs(VI_GetContainers()) do
        pcall(function()
            for _, desc in ipairs(c:GetDescendants()) do
                VI_WatchElement(desc)
            end
        end)
    end
end)
