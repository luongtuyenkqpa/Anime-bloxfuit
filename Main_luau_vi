do
    local InfoTab = Window:AddTab("Thông tin", "user")
    local InfoLeft  = InfoTab:AddLeftGroupbox("Thông tin người dùng")
    local InfoRight = InfoTab:AddRightGroupbox("Nhật ký thay đổi")

    -- Tên người chơi
    InfoLeft:AddLabel(LocalPlayer.DisplayName .. " (@" .. LocalPlayer.Name .. ")")
    InfoLeft:AddDivider()

    -- ── Lấy thông tin key từ getgenv() (do Animemodhub lưu sau khi xác thực) ──
    local keyLine  = "Key: Chưa đăng nhập"
    local typeLine = "Loại: —"
    local hsdLine  = "Hạn sử dụng: —"

    pcall(function()
        local vk  = (getgenv and getgenv()._amh_currentKey)        or ""
        local vkt = (getgenv and getgenv()._amh_currentKeyType)     or "NORMAL"
        local vet = (getgenv and getgenv()._amh_currentExpireTime)  or 0

        if vk ~= "" then
            keyLine = "Key: " .. string.sub(vk, 1, 10) .. "****"
            if vkt == "PREMIUM" or vkt == "VIP" or vkt == "PRO" then
                typeLine = "Loại: 👑 PREMIUM"
            else
                typeLine = "Loại: 🔰 THƯỜNG"
            end

            if vet and vet > 0 then
                local now  = os.time()
                local diff = vet - now
                if diff <= 0 then
                    hsdLine = "Hạn sử dụng: ⛔ ĐÃ HẾT HẠN"
                else
                    local days  = math.floor(diff / 86400)
                    local hours = math.floor((diff % 86400) / 3600)
                    local mins  = math.floor((diff % 3600) / 60)
                    if days > 0 then
                        hsdLine = string.format("Hạn sử dụng: Còn %d ngày %d giờ %d phút", days, hours, mins)
                    elseif hours > 0 then
                        hsdLine = string.format("Hạn sử dụng: Còn %d giờ %d phút", hours, mins)
                    else
                        hsdLine = string.format("Hạn sử dụng: Còn %d phút", mins)
                    end
                end
            else
                hsdLine = "Hạn sử dụng: Vĩnh viễn / Không rõ"
            end
        end
    end)

    InfoLeft:AddLabel(keyLine)
    InfoLeft:AddLabel(typeLine)
    InfoLeft:AddLabel(hsdLine)

    -- Nhật ký thay đổi (bên phải)
    InfoRight:AddLabel("11/7/2026")
    InfoRight:AddLabel("+ Đã thêm Chọn ESP Thực thể")
    InfoRight:AddLabel("+ Đã thêm Thông báo Vật phẩm")
    InfoRight:AddLabel("+ Đã thêm Xóa Surge")
