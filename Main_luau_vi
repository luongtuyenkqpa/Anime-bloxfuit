-- ── PATCH TIẾNG VIỆT TRIỆT ĐỂ: Dùng DescendantAdded để bắt mọi element realtime ──
-- Abysall tạo GUI muộn và liên tục cập nhật text → phải lắng nghe live thay vì quét 1 lần.
local VI_TextMap = {
    -- Nút title bar (quan trọng nhất)
    ["Toggle"]  = "Ẩn/Hiện",
    ["Lock"]    = "Khóa",
    -- Tab names (phòng khi library render lại)
    ["Info"]    = "Thông tin",
    ["General"] = "Tổng quát",
    ["Exploits"] = "Khai thác",
    ["Visuals"] = "Hiệu ứng",
    ["Floors"]  = "Các tầng",
    ["Settings"] = "Cài đặt",
}

local function VI_PatchElement(child)
    if not child then return end
    if child:IsA("TextLabel") or child:IsA("TextButton") then
        local vi = VI_TextMap[child.Text]
        if vi then
            child.Text = vi
        end
    end
end

local function VI_PatchTree(root)
    if not root then return end
    pcall(function()
        for _, desc in ipairs(root:GetDescendants()) do
            VI_PatchElement(desc)
        end
    end)
end

local function VI_GetContainers()
    local list = {}
    pcall(function()
        if Abysall and Abysall.Environment and Abysall.Environment.gethui then
            list[#list+1] = Abysall.Environment.gethui()
        end
    end)
    pcall(function() list[#list+1] = game:GetService("CoreGui") end)
    pcall(function() list[#list+1] = game:GetService("Players").LocalPlayer.PlayerGui end)
    return list
end

-- Kết nối DescendantAdded để bắt mọi element mới tạo ra (realtime)
local VI_Connections = {}
local function VI_StartWatchers()
    for _, container in ipairs(VI_GetContainers()) do
        pcall(function()
            local conn = container.DescendantAdded:Connect(function(child)
                VI_PatchElement(child)
                -- Nếu là Frame/ScrollingFrame mới, quét toàn bộ con của nó
                if child:IsA("Frame") or child:IsA("ScrollingFrame") or child:IsA("CanvasGroup") then
                    task.defer(function() VI_PatchTree(child) end)
                end
            end)
            table.insert(VI_Connections, conn)
        end)
    end
end

-- Theo dõi bền vững: nếu Abysall ghi đè lại text → đổi lại ngay
local VI_Watched = {}
local function VI_WatchElement(child)
    if not child then return end
    if not (child:IsA("TextLabel") or child:IsA("TextButton")) then return end
    if VI_Watched[child] then return end  -- đã theo dõi rồi

    -- Chỉ theo dõi nếu text hiện tại là 1 trong các key cần đổi
    local function tryPatch()
        local vi = VI_TextMap[child.Text]
        if vi then
            child.Text = vi
        end
    end

    pcall(function()
        local c = child:GetPropertyChangedSignal("Text"):Connect(function()
            -- Nếu text bị set lại về tiếng Anh → đổi lại
            local vi = VI_TextMap[child.Text]
            if vi and child.Text ~= vi then
                task.defer(function()
                    pcall(function() child.Text = vi end)
                end)
            end
        end)
        table.insert(VI_Connections, c)
        VI_Watched[child] = true
    end)
end

