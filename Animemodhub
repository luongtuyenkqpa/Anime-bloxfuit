                }):Play()
                task.wait(0.04)
                TweenService:Create(card, TweenInfo.new(0.04, Enum.EasingStyle.Linear), {
                    Position = origPos - UDim2.new(0, 7, 0, 0)
                }):Play()
                task.wait(0.04)
            end
            card.Position = origPos
        end
    end

    local function setLoading(loading)
        btn.Active = not loading
        btnLabel.Text = loading and "⏳  Verifying..." or "⚡  VERIFY KEY  ⚡"
    end

    -- ── Hiệu ứng VIP khi xác thực thành công ──
    local function playVipSuccessEffect(card)
        -- Mưa sao vàng + glow chớp
        local colors = {
            Color3.fromRGB(255, 215, 0),
            Color3.fromRGB(255, 100, 220),
            Color3.fromRGB(100, 220, 255),
            Color3.fromRGB(180, 100, 255),
        }
        for i = 1, 18 do
            task.spawn(function()
                local star = Instance.new("TextLabel")
                star.BackgroundTransparency = 1
                star.Text = ({"⭐","🌟","✨","💫","👑"})[math.random(5)]
                star.TextSize = math.random(14, 22)
                star.TextColor3 = colors[math.random(#colors)]
                star.Size = UDim2.new(0, 28, 0, 28)
                star.Position = UDim2.new(math.random(5, 90)/100, 0, math.random(10, 85)/100, 0)
                star.ZIndex = 20
                star.Parent = card
                TweenService:Create(star, TweenInfo.new(1.1, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {
                    Position = star.Position + UDim2.new(0, math.random(-40, 40), -0.3, 0),
                    TextTransparency = 1,
                }):Play()
                task.delay(1.15, function()
                    if star and star.Parent then star:Destroy() end
                end)
            end)
            task.wait(0.04)
        end
    end

    -- ── Hiệu ứng thường khi xác thực thành công ──
    local function playNormalSuccessEffect(card)
        local flash = Instance.new("Frame")
        flash.Size = UDim2.fromScale(1, 1)
        flash.BackgroundColor3 = Color3.fromRGB(50, 200, 80)
        flash.BackgroundTransparency = 0.7
        flash.ZIndex = 19
        flash.BorderSizePixel = 0
        flash.Parent = card
        Instance.new("UICorner", flash).CornerRadius = UDim.new(0, 18)
        TweenService:Create(flash, TweenInfo.new(0.5), {BackgroundTransparency = 1}):Play()
        task.delay(0.55, function()
            if flash and flash.Parent then flash:Destroy() end
        end)
    end

    -- FIX v9.1.3: _guiAlive theo dõi vòng đời GUI để tránh truy cập sau khi Destroy
    local _guiAlive = true
    -- _verifying ngăn bấm nút nhiều lần trong khi đang xác thực
    local _verifying = false

    local function doVerify()
        -- Chặn bấm 2 lần
        if _verifying or not _guiAlive then return end

        local key = input.Text:match("^%s*(.-)%s*$") -- trim
        if key == "" then
            setError("⚠️ Please enter your key.")
            return
        end

        _verifying = true
        errLabel.Text = ""
        errLabel.BackgroundTransparency = 1
        setLoading(true)
        btn.Active = false

        -- FIX v9.1.3: Toàn bộ verify flow nằm trong MỘT task.spawn duy nhất.
        -- verifyKey() là synchronous → httpPost block thread này cho đến khi xong.
        -- Không có callback pattern, không có thread nesting, không có race condition.
        task.spawn(function()
            -- ── Gọi server (blocking trên thread này) ──
            local result = nil
            local fetchTimedOut = false

            -- Timeout riêng: hủy nếu httpPost bị treo quá 20s
            local timeoutThread = task.delay(20, function()
                fetchTimedOut = true
            end)

            result = verifyKey(key)

            -- Nếu timeout đã kích hoạt thì bỏ qua kết quả trả về
            if fetchTimedOut then
                result = { valid = false, reason = "network_error" }
            else
                -- Hủy timeout vì đã có kết quả
                pcall(task.cancel, timeoutThread)
            end

            -- ── Xử lý kết quả ──
            if not _guiAlive then return end -- GUI đã bị đóng bởi luồng khác

            _verifying = false
            setLoading(false)
            pcall(function() btn.Active = true end)

            if result.valid then
                -- ── KEY HỢP LỆ ──
                keyVerified = true
                _currentVerifiedKey = key

                -- Xác định loại key từ server response
                local keyType = "NORMAL"
                local rawType = ""
                if result.type then
                    rawType = tostring(result.type):upper()
                elseif result.keyType then
                    rawType = tostring(result.keyType):upper()
                elseif result.tier then
                    rawType = tostring(result.tier):upper()
                elseif result.premium or result.isPremium then
                    rawType = "PREMIUM"
                end
                if rawType == "PREMIUM" or rawType == "PRO" or rawType == "VIP"
                   or rawType:find("PREMIUM") or rawType:find("PRO") or rawType:find("VIP") then
                    keyType = "PREMIUM"
                end
                _currentKeyType = keyType

                -- Lấy expire time
                local expireTime = 0
                local fieldOrder2 = {
                    "expiresAt","expireTime","expire_time","expires_at","expire",
                    "expiry","expiration","hsd","end_time","endTime","expiredAt"
                }
                for _, fld in ipairs(fieldOrder2) do
                    local v = result[fld]
                    if v ~= nil and v ~= "" and v ~= false then
                        local n = tonumber(v)
                        if n then
                            if n > 1e12 then n = math.floor(n/1000) end
                            expireTime = n
                        else
                            expireTime = parseDateTimeString(tostring(v))
                        end
                        if expireTime > 0 then break end
                    end
                end
                _currentExpireTime = expireTime
                saveKey(key, keyType, expireTime)

                -- Đổi màu input stroke thành xanh
                pcall(function() inputStroke.Color = Color3.fromRGB(50, 200, 80) end)

                -- Hiệu ứng thành công + toast
                local card = gui:FindFirstChild("Card")
                if keyType == "PREMIUM" or keyType == "VIP" then
                    showToast("KEY PREMIUM! Loading script...", Color3.fromRGB(200, 140, 0), "success")
                    if card then pcall(playVipSuccessEffect, card) end
                    task.wait(1.2)
                else
