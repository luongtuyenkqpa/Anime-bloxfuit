local function LoadBloxFruitsMenu()
-- ↑ Phần xác thực key kết thúc. Script gốc bắt đầu từ đây ↓

-- FIX v9.1.3.1: hookfunction/require ở đây trước đây KHÔNG được bọc pcall.
-- Nếu executor không hỗ trợ hookfunction, hoặc module Effect.Container.Death/Respawn
-- chưa kịp replicate/đổi đường dẫn do game update, hàm onSuccess sẽ ném lỗi NGAY LẬP TỨC
-- tại đây — tức là TRƯỚC CẢ khi kiểm tra game Blox Fruits và trước khi menu được dựng.
-- Vì key-gate GUI đã bị Destroy trước khi gọi onSuccess (xem pcall(onSuccess) phía trên),
-- lỗi này chỉ in ra console (warn) mà người chơi không thấy gì cả → CẢM GIÁC NHƯ "CRASH"
-- dù key đã nhập đúng. Bọc pcall + thông báo rõ ràng để không bao giờ bị "im lặng" nữa.
local _hookOk, _hookErr = pcall(function()
    hookfunction(require(game:GetService("ReplicatedStorage").Effect.Container.Death), function()
        -- empty block
    end)
    hookfunction(require(game:GetService("ReplicatedStorage").Effect.Container.Respawn), function()
        -- empty block
    end)
end)
if not _hookOk then
    warn("[AnimeModHub] Cảnh báo: hookfunction Death/Respawn thất bại (bỏ qua, không chặn menu): " .. tostring(_hookErr))
    pcall(function()
        game:GetService("StarterGui"):SetCore("SendNotification", {
            Title = "⚠️ ANIME MOD HUB";
            Text = "Một số hiệu ứng phụ không thể hook (executor không hỗ trợ) — menu vẫn tiếp tục tải.";
            Duration = 5;
        })
    end)
end
