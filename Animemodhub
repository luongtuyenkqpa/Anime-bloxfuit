                saveCurrentSize()
                TweenService:Create(main, TweenInfo.new(0.22, Enum.EasingStyle.Quart, Enum.EasingDirection.In), {
                    Size = UDim2.new(0, main.AbsoluteSize.X, 0, 0),
                    BackgroundTransparency = 1,
