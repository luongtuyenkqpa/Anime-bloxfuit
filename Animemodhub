            if _rDragging and (inp.UserInputType == Enum.UserInputType.MouseMovement or inp.UserInputType == Enum.UserInputType.Touch) then
                local delta = inp.Position - _rStart
                local newW = math.clamp(_rStartSize.X + delta.X, MIN_W, MAX_W)
                local newH = math.clamp(_rStartSize.Y + delta.Y, MIN_H, MAX_H)
                main.Size = UDim2.new(0, newW, 0, newH)
