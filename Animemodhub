-- ──────────────────────────────────────────────────────────
--  Format thời gian hết hạn từ timestamp
-- ──────────────────────────────────────────────────────────
local function formatExpiry(expireTimestamp)
    if not expireTimestamp or expireTimestamp == 0 then
        return "Không xác định"
    end
    -- expireTimestamp là Unix timestamp (giây)
    local now = os.time()
    local diff = expireTimestamp - now
    if diff <= 0 then
        return "ĐÃ HẾT HẠN"
    end
    local days = math.floor(diff / 86400)
    local hours = math.floor((diff % 86400) / 3600)
    local mins = math.floor((diff % 3600) / 60)
    if days > 0 then
        return string.format("%d ngày %d giờ %d phút", days, hours, mins)
    elseif hours > 0 then
        return string.format("%d giờ %d phút", hours, mins)
    else
        return string.format("%d phút", mins)
    end
end

