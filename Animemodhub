local SAVE_FILE = "AnimeModHub_SavedKey.txt"
local _savedKeyData = { key = "", keyType = "NORMAL", expireTime = 0 }

local function loadSavedKey()
    local ok, data = pcall(function()
        if isfile and isfile(SAVE_FILE) then
            return HttpService:JSONDecode(readfile(SAVE_FILE))
        end
    end)
    if ok and data and data.key and data.key ~= "" then
        _savedKeyData = data
        return data
    end
    return nil
end

local function saveKey(key, keyType, expireTime)
    pcall(function()
        if writefile then
            writefile(SAVE_FILE, HttpService:JSONEncode({
                key = key,
                keyType = keyType or "NORMAL",
                expireTime = expireTime or 0
            }))
        end
    end)
    _savedKeyData.key = key
    _savedKeyData.keyType = keyType or "NORMAL"
    _savedKeyData.expireTime = expireTime or 0
end

-- Xoá key đã lưu khi key hết hạn / bị ban / không tồn tại
local function deleteSavedKey()
    pcall(function()
        if delfile and isfile and isfile(SAVE_FILE) then
            delfile(SAVE_FILE)
        elseif writefile then
            -- Fallback: ghi file rỗng nếu executor không có delfile
            writefile(SAVE_FILE, HttpService:JSONEncode({ key = "", keyType = "NORMAL", expireTime = 0 }))
        end
    end)
    _savedKeyData = { key = "", keyType = "NORMAL", expireTime = 0 }
end

-- ──────────────────────────────────────────────────────────
--  Background key checker (kiểm tra key ngầm mỗi 60s)
-- ──────────────────────────────────────────────────────────
local _bgCheckActive = false
local _onKeyInvalidCallback = nil

-- ──────────────────────────────────────────────────────────
--  HTTP helper — POST JSON body (bypass HoHo Hub key-format hook)
--  HoHo Hub intercepts GET ?key=... và validate format → KEY_INVALID
--  Gửi qua POST body thì HoHo Hub không parse → không bị block
--  v2: retry 3 lần, timeout check, nhiều executor hơn
-- ──────────────────────────────────────────────────────────
local function httpPost(url, payload)
    local body    = HttpService:JSONEncode(payload)
    local headers = {
        ["Content-Type"] = "application/json",
        ["Accept"]       = "application/json",
    }

    -- Hàm thực hiện 1 lần POST — trả về body string hoặc nil
    local function tryPost()
        -- 1) request() — HoHo Hub, Fluxus, Codex, Delta, Wave...
        if request then
            local ok, res = pcall(request, {
                Url     = url,
                Method  = "POST",
                Headers = headers,
                Body    = body,
            })
            if ok and res and res.Body and #res.Body > 0 then
                return res.Body
            end
        end
        -- 2) syn.request — Synapse X / Synapse Z
        if syn and syn.request then
            local ok, res = pcall(syn.request, {
                Url     = url,
                Method  = "POST",
                Headers = headers,
                Body    = body,
            })
            if ok and res and res.Body and #res.Body > 0 then
                return res.Body
            end
        end
        -- 3) http.request — một số executor khác (Krnl, Electron...)
        if http and http.request then
            local ok, res = pcall(http.request, {
                Url     = url,
                Method  = "POST",
                Headers = headers,
                Body    = body,
            })
            if ok and res and res.Body and #res.Body > 0 then
                return res.Body
            end
        end
        -- 4) HttpService.RequestAsync (Roblox Studio / các executor mới)
        if HttpService.RequestAsync then
            local ok, res = pcall(function()
                return HttpService:RequestAsync({
                    Url     = url,
                    Method  = "POST",
                    Headers = headers,
                    Body    = body,
                })
            end)
            if ok and res and res.Body and #res.Body > 0 then
                return res.Body
            end
        end
        return nil
    end

    -- Retry 3 lần với delay tăng dần (1s, 2s, 3s)
    for attempt = 1, 3 do
        local result = tryPost()
        if result then return result end
        if attempt < 3 then
            task.wait(attempt) -- 1s, sau đó 2s trước lần thứ 3
        end
    end

    -- Fallback cuối: GET (Roblox Studio / executor không hỗ trợ POST body)
    -- Cũng gửi device + platform để server phân slot đúng
    local getUrl = url
        .. "?key="      .. HttpService:UrlEncode(tostring(payload.key      or ""))
        .. "&app="      .. HttpService:UrlEncode(tostring(payload.app      or ""))
        .. "&device="   .. HttpService:UrlEncode(tostring(payload.device   or ""))
        .. "&platform=" .. HttpService:UrlEncode(tostring(payload.platform or ""))
    local ok, result = pcall(function()
        return game:HttpGet(getUrl)
    end)
    if ok and result and #result > 0 then return result end

    -- Không thể kết nối server
    return nil
end

local function startBackgroundKeyCheck(key, onInvalid)
    if _bgCheckActive then return end
    _bgCheckActive = true
    _onKeyInvalidCallback = onInvalid
    task.spawn(function()
        while _bgCheckActive do
            task.wait(60) -- kiểm tra mỗi 60 giây
            if not _bgCheckActive then break end
            local ok, result = pcall(function()
                return HttpService:JSONDecode(httpPost(
                    SERVER_URL .. "/api/verify",
                    { key = key, app = APP_ID, device = _LUA_DEVICE_ID, platform = "roblox" }
                ))
            end)
            if ok and result then
                if not result.valid then
                    local reason = result.reason or "unknown"
                    -- Key bị ban hoặc hết hạn → auto quay về màn đăng nhập
                    if reason == "expired" or reason == "banned" or reason == "key_not_found" then
                        _bgCheckActive = false
                        if _onKeyInvalidCallback then
                            _onKeyInvalidCallback(reason)
                        end
                        break
                    end
                end
            end
        end
    end)
end

local function stopBackgroundKeyCheck()
    _bgCheckActive = false
end

-- ──────────────────────────────────────────────────────────
-- FIX v9.1.3: verifyKey là hàm SYNCHRONOUS thuần túy — chỉ gửi HTTP và trả kết quả.
-- Việc tạo thread/task.spawn hoàn toàn do doVerify quản lý để tránh thread nesting.
local function verifyKey(key)
    local rawBody = nil
    local fetchOk = pcall(function()
        rawBody = httpPost(
            SERVER_URL .. "/api/verify",
            { key = key, app = APP_ID, device = _LUA_DEVICE_ID, platform = "roblox" }
        )
    end)

    -- Không nhận được response gì từ server
    if not fetchOk or not rawBody or rawBody == "" then
        return { valid = false, reason = "network_error" }
    end

    -- Parse JSON response
    local parseOk, result = pcall(function()
        return HttpService:JSONDecode(rawBody)
    end)

    if parseOk and result and type(result) == "table" then
        return result
    else
        -- Server trả về response không hợp lệ (bị truncate, HTML error page...)
        return { valid = false, reason = "server_error" }
    end
end

