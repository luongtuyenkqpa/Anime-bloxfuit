            local HOLD_DELAY  = 0.35 -- giây trước khi bắt đầu cuộn liên tục
            local HOLD_RATE   = 0.06 -- giây giữa mỗi bước cuộn khi giữ

            local function applyScroll(dir)
                local maxScroll = math.max(0, tabList.AbsoluteCanvasSize.Y - tabList.AbsoluteSize.Y)
                local newY = math.clamp(tabList.CanvasPosition.Y + dir * SCROLL_STEP, 0, maxScroll)
                TweenService:Create(tabList, TweenInfo.new(0.12, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
                    CanvasPosition = Vector2.new(0, newY)
                }):Play()
            end

            local function attachHold(btn, dir)
                local holding = false
                btn.MouseButton1Down:Connect(function()
                    holding = true
                    applyScroll(dir)  -- bước đầu ngay lập tức
                    task.delay(HOLD_DELAY, function()
                        while holding and btn and btn.Parent do
                            applyScroll(dir)
                            task.wait(HOLD_RATE)
                        end
                    end)
                end)
                btn.MouseButton1Up:Connect(function() holding = false end)
                btn.MouseLeave:Connect(function() holding = false end)
            end

