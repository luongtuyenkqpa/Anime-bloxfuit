-- ── Parse datetime string từ server ──
-- Hỗ trợ: ISO 8601 ("2026-07-12T19:36:00.000Z"), "HH:MM DD/MM/YYYY", "DD/MM/YYYY HH:MM", Unix ts
local function parseDateTimeString(s)
    if not s then return 0 end
    s = tostring(s)

    -- Format 0 (QUAN TRỌNG): ISO 8601 — đây là format server thực tế trả về
    -- VD: "2026-07-12T19:36:00.000Z" hoặc "2026-07-12T19:36:00Z"
    local y0, mo0, d0, h0, m0, sec0 = s:match("(%d%d%d%d)-(%d%d)-(%d%d)T(%d%d):(%d%d):(%d%d)")
    if y0 then
        -- Server lưu UTC, os.time() dùng local time → cộng thêm UTC offset của máy
        -- Cách an toàn: tính bằng số giây thủ công
        local t = os.time({year=tonumber(y0), month=tonumber(mo0), day=tonumber(d0),
                           hour=tonumber(h0), min=tonumber(m0), sec=tonumber(sec0 or 0)})
        -- Bù offset UTC→Local: os.time() interpret theo localtime, nhưng input là UTC
        -- Tính offset = os.time() của cùng struct so với os.time(os.date("*t"))
        local utcNow = os.time(os.date("!*t"))  -- UTC now
        local localNow = os.time()               -- local now
        local offsetSec = localNow - utcNow      -- offset (VN = +25200)
        return t + offsetSec
    end

    -- Format 1: "19:36 12/07/2026"  (HH:MM DD/MM/YYYY)
    local h, m, d, mo, y = s:match("(%d+):(%d+)%s+(%d+)/(%d+)/(%d+)")
    if h then
        return os.time({year=tonumber(y), month=tonumber(mo), day=tonumber(d),
                        hour=tonumber(h), min=tonumber(m), sec=0})
    end
    -- Format 2: "12/07/2026 19:36"
    local d2, mo2, y2, h2, m2 = s:match("(%d+)/(%d+)/(%d+)%s+(%d+):(%d+)")
    if d2 then
        return os.time({year=tonumber(y2), month=tonumber(mo2), day=tonumber(d2),
                        hour=tonumber(h2), min=tonumber(m2), sec=0})
    end
    -- Format 3: số thuần (Unix timestamp)
    local n = tonumber(s)
    if n then
        if n > 1e12 then n = math.floor(n/1000) end
        return n
    end
    return 0
end

-- ── Fetch fresh data từ server để lấy HSD chính xác ──
local function fetchFreshExpiry(callback)
    if _currentVerifiedKey == "" then callback(0) return end
    task.spawn(function()
        local ok, res = pcall(function()
            return HttpService:JSONDecode(httpPost(
                SERVER_URL .. "/api/verify",
                { key = _currentVerifiedKey, app = APP_ID, device = _LUA_DEVICE_ID, platform = "roblox" }
            ))
        end)
        if ok and res and res.valid then
            -- Thử tất cả field có thể có HSD (ưu tiên expiresAt — field chính của server)
            local expireTime = 0
            local fieldOrder = {
                "expiresAt","expireTime","expire_time","expires_at","expire",
                "expiry","expiration","hsd","end_time","endTime","expiredAt"
            }
            for _, field in ipairs(fieldOrder) do
                local v = res[field]
                if v ~= nil and v ~= "" and v ~= false then
                    local n = tonumber(v)
                    if n then
                        if n > 1e12 then n = math.floor(n/1000) end
                        expireTime = n
                    else
                        expireTime = parseDateTimeString(tostring(v))
                    end
                    if expireTime > 0 then break end
                end
            end
            -- Cập nhật biến global nếu lấy được
            if expireTime > 0 then _currentExpireTime = expireTime end
            -- Cập nhật keyType từ server nếu có (type lowercase: "premium"/"normal")
            if res.type and res.type ~= "" then
                local rt = tostring(res.type):upper()
                if rt == "PREMIUM" or rt == "PRO" or rt == "VIP" then
                    _currentKeyType = "PREMIUM"
                else
                    _currentKeyType = "NORMAL"
                end
            end
            callback(expireTime)
        else
            callback(_currentExpireTime)
        end
    end)
end

local function buildHSDText()
    local keyDisplay
    if _currentVerifiedKey ~= "" then
        -- Hiện đầy đủ hơn: ví dụ "NÚNG À EM-****"
        local keyShort = string.sub(_currentVerifiedKey, 1, 12)
        keyDisplay = "Key: " .. keyShort .. "****"
    else
        keyDisplay = "Key: Chưa đăng nhập"
    end

    local typeIcon
    if _currentKeyType == "PREMIUM" or _currentKeyType == "VIP" or _currentKeyType == "PRO" then
        typeIcon = "👑 PREMIUM"
    else
        typeIcon = "🔰 THƯỜNG"
    end

    local hsdText
    local expTime = _currentExpireTime
    if expTime and expTime > 0 then
        local now = os.time()
        local diff = expTime - now
        if diff <= 0 then
            hsdText = "HSD: ⛔ ĐÃ HẾT HẠN"
        else
            -- Format đúng như server: "Còn X giờ Y phút" hoặc "Còn X ngày Y giờ"
            local days  = math.floor(diff / 86400)
            local hours = math.floor((diff % 86400) / 3600)
            local mins  = math.floor((diff % 3600) / 60)
            local secs  = diff % 60
            local remainStr
            if days > 0 then
                remainStr = string.format("Còn %d ngày %d giờ %d phút", days, hours, mins)
            elseif hours > 0 then
                remainStr = string.format("Còn %d giờ %d phút %d giây", hours, mins, secs)
            else
                remainStr = string.format("Còn %d phút %d giây", mins, secs)
            end
            -- Ngày hết hạn local (giống server hiển thị)
            local expireStr = os.date("%H:%M %d/%m/%Y", expTime)
            hsdText = "HSD: " .. expireStr .. "\n⏳ " .. remainStr
        end
    else
        -- Không có expire time → thử fetch từ server
        hsdText = "HSD: Đang lấy thông tin..."
    end

    return keyDisplay .. "\nLoại key: " .. typeIcon .. "\n" .. hsdText .. "\n\n• Key hết hạn sẽ tự động đăng xuất\n• Mỗi key giới hạn 1 thiết bị"
end

