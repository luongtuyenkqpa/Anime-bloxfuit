        tabLayout.Parent = tabList

        local tabPadding = Instance.new("UIPadding")
        tabPadding.PaddingTop = UDim.new(0, 6)
        tabPadding.PaddingLeft = UDim.new(0, 6)
        tabPadding.PaddingRight = UDim.new(0, 6)
        tabPadding.Parent = tabList

        -- ─── TOUCH DRAG-TO-SCROLL cho tabList (mobile) ───────────
        -- ScrollingFrame không auto-scroll trên mobile khi chứa TextButton
        -- → thêm drag thủ công: vuốt lên/xuống để cuộn menu
        -- FIX v9.1.3.3: khai báo _scrollBtnsRef trước các do-block để tránh
        -- dùng window trước khi nó được khai báo (gây freeze menu)
        local _scrollBtnsRef = nil
        do
            local UIS = game:GetService("UserInputService")
            local _tDragging   = false
            local _tStartY     = 0
            local _tStartCanvas = 0
            local _tLastY      = 0
            local _tVelocity   = 0
            local _tLastTime   = 0
            local _tInertiaConn = nil

            -- Bắt đầu kéo
            tabList.InputBegan:Connect(function(inp)
                if inp.UserInputType == Enum.UserInputType.Touch
                   or inp.UserInputType == Enum.UserInputType.MouseButton1 then
                    _tDragging    = true
                    _tStartY      = inp.Position.Y
                    _tLastY       = inp.Position.Y
                    _tStartCanvas = tabList.CanvasPosition.Y
                    _tVelocity    = 0
                    _tLastTime    = tick()
                    -- Dừng inertia nếu đang chạy
                    if _tInertiaConn then _tInertiaConn:Disconnect(); _tInertiaConn = nil end
                end
            end)

            -- Kéo đang chạy
            UIS.InputChanged:Connect(function(inp)
                if not _tDragging then return end
                if inp.UserInputType ~= Enum.UserInputType.Touch
                   and inp.UserInputType ~= Enum.UserInputType.MouseMovement then return end

                local now = tick()
                local dt  = now - _tLastTime
                if dt > 0 then
                    _tVelocity = (inp.Position.Y - _tLastY) / dt
                end
                _tLastY    = inp.Position.Y
                _tLastTime = now

                local delta   = inp.Position.Y - _tStartY
                local maxScroll = math.max(0, tabList.AbsoluteCanvasSize.Y - tabList.AbsoluteSize.Y)
                local newY    = math.clamp(_tStartCanvas - delta, 0, maxScroll)
                tabList.CanvasPosition = Vector2.new(0, newY)
            end)

            -- Kết thúc kéo → inertia (tiếp tục trôi)
            UIS.InputEnded:Connect(function(inp)
                if not _tDragging then return end
                if inp.UserInputType ~= Enum.UserInputType.Touch
                   and inp.UserInputType ~= Enum.UserInputType.MouseButton1 then return end
                _tDragging = false

                -- Inertia: trôi dần sau khi buông tay
                local vel = -_tVelocity  -- đảo chiều: vuốt xuống → canvas đi lên
                _tInertiaConn = game:GetService("RunService").Heartbeat:Connect(function(dt)
                    if math.abs(vel) < 1 then
                        if _tInertiaConn then _tInertiaConn:Disconnect(); _tInertiaConn = nil end
                        return
                    end
                    local maxScroll = math.max(0, tabList.AbsoluteCanvasSize.Y - tabList.AbsoluteSize.Y)
