-- ──────────────────────────────────────────────────────────
local keyVerified = false
local _currentVerifiedKey = ""
local _currentKeyType = "NORMAL"
local _currentExpireTime = 0

local function startKeyGate(onSuccess)
    local gui, btn, input, errLabel, btnLabel, inputStroke = createKeyGUI()

    local function setError(msg)
        errLabel.TextColor3 = Color3.fromRGB(255, 100, 130)
        errLabel.Text = msg
        errLabel.BackgroundTransparency = 0.3
        -- Rung card
        local card = gui:FindFirstChild("Card")
