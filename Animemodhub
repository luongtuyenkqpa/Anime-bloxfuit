        main.BorderSizePixel = 0
        main.Active = true
        main.Parent = gui
        addCorner(main, 12)

        local mainStroke = Instance.new("UIStroke")
        mainStroke.Color = Color3.fromRGB(100, 50, 220)
        mainStroke.Thickness = 1.5
        mainStroke.Parent = main

        -- Outer glow animation on border
        task.spawn(function()
            local glowColors = {
                Color3.fromRGB(100, 50, 255),
                Color3.fromRGB(0, 160, 255),
                Color3.fromRGB(220, 60, 200),
                Color3.fromRGB(60, 220, 200),
            }
            local idx = 1
            while main and main.Parent do
                idx = idx % #glowColors + 1
                TweenService:Create(mainStroke, TweenInfo.new(2, Enum.EasingStyle.Sine), {
                    Color = glowColors[idx]
